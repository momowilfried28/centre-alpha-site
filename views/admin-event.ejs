<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - Événement</title>
    <link rel="stylesheet" href="/css/editeur_text.css" />
  </head>
  <body class="admin-bg-themed">
    <div class="container">
      <header class="admin-page-header">
        <h1>Événements</h1>
        <p class="admin-page-header__sub">
Gérez les affiches de la page Événements du site.        </p>
      </header>

      <nav class="admin-subnav" aria-label="Navigation administration">
        <a class="admin-subnav__link" href="/admin/dictee">Modifier la dictée</a>
        <span class="admin-subnav__link admin-subnav__link--current">Modifier l’événement</span>
      </nav>

      <section class="admin-card" aria-labelledby="upload-title">
        <h2 id="upload-title" class="admin-card__title">Ajouter une affiche</h2>
        <p class="admin-card__hint">JPEG, PNG, GIF ou WebP — maximum 5&nbsp;Mo.</p>
        <form
          method="POST"
          action="/admin/event/upload-image"
          enctype="multipart/form-data"
          class="admin-file-row">
          <input type="file" name="image" accept="image/jpeg,image/png,image/gif,image/webp" required />
          <button type="submit">Téléverser</button>
        </form>
      </section>

      <% if (typeof images !== "undefined" && images.length) { %>
        <section class="admin-card" aria-labelledby="list-title">
          <h2 id="list-title" class="admin-card__title">Affiches en cours</h2>
          <ul class="admin-image-list">
            <% images.forEach(function (item) { %>
              <li class="admin-image-card">
                <img
                  class="admin-image-card__thumb"
                  src="<%= item.url %>"
                  alt=""
                  loading="lazy"
                  width="88"
                  height="88" />
                <p class="admin-image-card__label"><%= item.label %></p>
                <div class="admin-image-card__actions">
                  <form method="POST" action="/admin/event/delete-image">
                    <input type="hidden" name="url" value="<%= item.url %>" />
                    <button type="submit" class="admin-btn--danger">Supprimer</button>
                  </form>
                </div>
              </li>
            <% }); %>
          </ul>
        </section>
      <% } else { %>
        <section class="admin-event-placeholder" aria-live="polite">
          <p class="admin-empty">
            <strong>Aucune affiche pour le moment.</strong> Ajoutez-en une avec le formulaire ci-dessus.
          </p>
        </section>
      <% } %>

    
    </div>
  </body>
</html>
