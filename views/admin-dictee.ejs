<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - Dictée</title>
    <style>
      * { box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; background: #f1f5f9; margin: 0; padding: 24px; }
      .container { max-width: 960px; margin: 0 auto; }
      h1 { font-size: 1.4rem; color: #1e293b; margin-bottom: 20px; }

      .editor-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        align-items: start;
      }
      .panel {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
      }
      .panel-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 10px 14px;
        font-size: 0.82rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      textarea {
        width: 100%;
        min-height: 520px;
        font-size: 0.95rem;
        line-height: 1.6;
        padding: 14px;
        border: none;
        outline: none;
        resize: vertical;
        font-family: "Courier New", monospace;
        color: #334155;
      }
      .preview-body {
        min-height: 520px;
        padding: 14px;
        white-space: pre-wrap;
        word-wrap: break-word;
        font-family: "Inter", system-ui, sans-serif;
        font-size: 0.95rem;
        line-height: 1.75;
        color: #334155;
      }
      .preview-body a { color: #2563eb; }

      .actions {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-top: 16px;
      }
      button[type="submit"] {
        padding: 10px 22px;
        font-size: 1rem;
        font-weight: 600;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 8px;
        cursor: pointer;
      }
      button[type="submit"]:hover { background: #1d4ed8; }
      .ok { color: #16a34a; font-weight: 600; font-size: 0.95rem; }
      .legend {
        margin-top: 14px;
        font-size: 0.82rem;
        color: #94a3b8;
      }
      .legend code {
        background: #f1f5f9;
        border-radius: 4px;
        padding: 1px 5px;
        font-family: monospace;
        color: #475569;
      }
      a { color: #2563eb; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Admin — Dictée</h1>

      <% if (typeof saved !== "undefined" && saved) { %>
        <div class="ok" style="margin-bottom:12px">✅ Sauvegardé avec succès.</div>
      <% } %>

      <form method="POST" action="/admin/dictee">
        <div class="editor-grid">
          <div class="panel">
            <div class="panel-header">✏️ Éditeur</div>
            <textarea
              id="text"
              name="text"
              oninput="updatePreview()"
              spellcheck="true"
            ><%= typeof text !== "undefined" && text != null ? text : "" %></textarea>
          </div>

          <div class="panel">
            <div class="panel-header">👁️ Aperçu (tel qu'affiché sur le site)</div>
            <div class="preview-body" id="preview"></div>
          </div>
        </div>

        <div class="actions">
          <button type="submit">Enregistrer</button>
          <a href="/dictee" target="_blank">Voir la page publique →</a>
        </div>
      </form>

      <p class="legend">
        Formatage supporté :
        <code>__texte__</code> = <u>souligné</u> &nbsp;|&nbsp;
        <code>**texte**</code> = <strong>gras</strong> &nbsp;|&nbsp;
        <code>https://...</code> = lien cliquable
      </p>
    </div>

    <script>
      function renderMarkdown(raw) {
        if (!raw) return "";

        // 1. Escape HTML
        let out = raw
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;");

        // 2. Gras : **texte**
        out = out.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");

        // 3. Souligné : __texte__
        out = out.replace(/__(.+?)__/g, "<u>$1</u>");

        // 4. Liens cliquables : http:// ou https://
        out = out.replace(
          /(https?:\/\/[^\s<]+)/g,
          '<a href="$1" target="_blank" rel="noopener noreferrer">$1</a>'
        );

        return out;
      }

      function updatePreview() {
        const raw = document.getElementById("text").value;
        document.getElementById("preview").innerHTML = renderMarkdown(raw);
      }

      updatePreview();
    </script>
  </body>
</html>
