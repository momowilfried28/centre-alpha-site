<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Centre Alpha – Événements</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,100..900;1,100..900&family=Satisfy&display=swap"
      rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet" />

    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/animate.css" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/home.css" />
    <link rel="stylesheet" href="/css/services.css" />
    <link rel="stylesheet" href="/css/evenements.css" />
  </head>

  <body class="hero-section page-services page-evenements">
    <%- include("partials/navbar") %>

    <main class="accueil-container services-page">
      <section class="intro fade-in" aria-label="Événements">
        <h1 class="intro-titre">Événements</h1>
        <p class="intro-texte">
Des moments pour se rassembler, apprendre et grandir ensemble. Chaque activité valorise nos apprenants et nos bénévoles, et soutient l’autonomie de toute la communauté.        </p>
      </section>

      <section class="evenements-galerie fade-in" aria-label="Affiches et annonces">
        <% const imgs = typeof images !== "undefined" && Array.isArray(images) ? images : []; %>
        <% imgs.forEach(function (item) { %>
          <figure class="evenements-galerie__figure">
            <img
              class="evenements-galerie__img"
              src="<%= item.url %>"
              alt="<%= item.label %>" />
          </figure>
        <% }); %>
      </section>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
